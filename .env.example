# Generic dummy .env for local development
# Copy this to .env and fill in the values

# ==========================================
# 1. AWS Configuration
# ==========================================
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your_s3_bucket
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# [IMPORTANT] 
# LOCAL DEV: Leave these blank if you have run 'aws configure'. 
# Boto3 will automatically use your local CLI credentials.
# DOCKER/PROD: You MUST fill these in.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# ==========================================
# 2. Database Configuration
# ==========================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password_must_be_at_least_8_chars

# ==========================================
# 3. Redis Configuration
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379

# ==========================================
# 4. Application Settings
# ==========================================
LOG_LEVEL=INFO
DEBUG=True
