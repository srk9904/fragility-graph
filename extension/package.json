{
    "name": "fragility-graph",
    "displayName": "FragilityGraph",
    "description": "Real-time AI code fragility analysis",
    "version": "0.0.1",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "fragility-graph.analyze",
                "title": "FragilityGraph: Analyze Project"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/node": "18.x",
        "typescript": "^5.1.3",
        "eslint": "^8.41.0"
    },
    "dependencies": {
        "isomorphic-ws": "^5.0.0",
        "ws": "^8.13.0"
    }
}
